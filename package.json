{
    "name": "subquiz",
    "private": true,
    "version": "3.3.3.7",
    "versionId": 30303007,
    "minVersionId": 30303007,
    "downloadUrl": "https://quiz.bdfzscc.com/SubQuiz.apk",
    "aiDownloadUrl": "https://quiz.bdfzscc.com/SubQuizAI.apk",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build-web": "ts-node update-version.ts && rm -rf dist/* && vue-tsc -b && vite build",
        "typecheck:react": "tsc -p tsconfig.react.json --noEmit",
        "build-android": "npx cap sync && npx cap build android && cp ./android/app/build/outputs/apk/release/app-release-signed.apk ./dist/SubQuiz.apk",
        "build": "npm run build-web && npm run build-android && rm -rf dist/assets/*.woff2 dist/assets/*.woff dist/assets/*.ttf",
        "build-ai": "ts-node update-version.ts ai && rm -rf dist/* && vue-tsc -b && vite build && npm run build-android && rm -rf dist/assets/*.woff2 dist/assets/*.woff dist/assets/*.ttf",

        "build-all": "npm run build && mv ./dist ./tmp_dist && npm run build-ai && mv ./dist/SubQuiz.apk ./tmp_dist/SubQuizAI.apk && rm -rf ./dist && mv ./tmp_dist ./dist",
        "preview": "vite preview"
    },
    "dependencies": {
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/preset-env": "^7.28.3",
        "@babel/preset-typescript": "^7.27.1",
        "@capacitor-community/file-opener": "^7.0.1",
        "@capacitor/android": "^7.0.2",
        "@capacitor/app": "^7.0.2",
        "@capacitor/camera": "^7.0.2",
        "@capacitor/clipboard": "^7.0.2",
        "@capacitor/core": "^7.0.2",
        "@capacitor/device": "^7.0.2",
        "@capacitor/filesystem": "^7.0.2",
        "@capacitor/keyboard": "^7.0.2",
        "@capacitor/preferences": "^7.0.2",
        "@capacitor/screen-orientation": "^7.0.2",
        "@capawesome/capacitor-android-dark-mode-support": "^7.0.0",
        "@capgo/inappbrowser": "^7.12.1",
        "@headlessui/vue": "^1.7.23",
        "@heroicons/vue": "^2.2.0",
        "@ionic/pwa-elements": "^3.3.0",
        "@wooorm/starry-night": "^3.8.0",
        "ansi_up": "^6.0.2",
        "desmos": "^1.5.4",
        "hast-util-to-html": "^9.0.5",
        "html2canvas": "^1.4.1",
        "katex": "^0.16.22",
        "marked": "^15.0.7",
        "mathjax": "^3.2.2",
        "spark-md5": "^3.0.2",
        "vite-plugin-babel": "^1.3.2",
        "vite-plugin-inspect": "^10.1.1",
        "vue": "^3.5.13",
        "vue-material-design-icons": "^5.3.1",
        "vue-router": "^4.5.0"
    },
    "devDependencies": {
        "@capacitor/cli": "^7.0.2",
        "@types/node": "^22.13.1",
        "@vitejs/plugin-vue": "^5.2.1",
        "@vitejs/plugin-vue-jsx": "^4.2.0",
        "@vue/tsconfig": "^0.7.0",
        "autoprefixer": "^10.4.21",
        "glob": "^11.0.1",
        "postcss": "^8.5.6",
        "postcss-import": "^16.1.1",
        "postcss-nesting": "^13.0.2",
        "postcss-preset-env": "^10.2.4",
        "sass": "^1.85.0",
        "terser": "^5.39.0",
        "typescript": "~5.6.2",
        "vite": "^6.3.5",
        "vue-tsc": "^2.2.0"
    },
    "browserslist": {
        "production": [
            "chrome >= 70",
            "firefox >= 65",
            "safari >= 12",
            "edge >= 79",
            "ios_saf >= 12",
            "android >= 70"
        ],
        "development": [
            "chrome >= 70",
            "firefox >= 65",
            "safari >= 12",
            "edge >= 79",
            "ios_saf >= 12",
            "android >= 70"
        ]
    }
}
