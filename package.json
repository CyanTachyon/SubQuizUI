{
    "name": "subquiz",
    "private": true,
    "version": "3.4.0.14",
    "versionId": 30400014,
    "minVersionId": 30400012,
    "downloadUrl": "https://quiz.bdfzscc.com/SubQuiz.apk",
    "aiDownloadUrl": "https://quiz.bdfzscc.com/SubQuizAI.apk",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "clean": "rm -rf dist/* && rm -rf build/* && mkdir -p build",
        "set-default-mode": "ts-node update-version.ts",
        "set-ai-mode": "ts-node update-version.ts ai",
        "build-web": "vue-tsc -b && vite build",
        "build-android": "npx cap sync && npx cap build android && cp ./android/app/build/outputs/apk/release/app-release-signed.apk ./dist/SubQuiz.apk",
        "build": "npm run build-web && npm run build-android && rm -rf dist/assets/*.woff2 dist/assets/*.woff dist/assets/*.ttf",
        "build-all": "npm run clean && npm run set-default-mode && npm run build && mv ./dist ./build/default && npm run set-ai-mode && npm run build && mv ./dist ./build/ai && mv ./build/ai/SubQuiz.apk ./build/default/SubQuizAI.apk && cp ./build/default/*.apk ./build/ai/",
        "preview": "vite preview"
    },
    "dependencies": {
        "@babel/plugin-syntax-dynamic-import": "^7.8.3",
        "@babel/preset-env": "^7.28.3",
        "@babel/preset-typescript": "^7.27.1",
        "@capacitor-community/file-opener": "^7.0.1",
        "@capacitor/android": "^7.4.4",
        "@capacitor/app": "^7.1.0",
        "@capacitor/camera": "^7.0.2",
        "@capacitor/clipboard": "^7.0.2",
        "@capacitor/core": "^7.4.4",
        "@capacitor/device": "^7.0.2",
        "@capacitor/filesystem": "^7.1.4",
        "@capacitor/keyboard": "^7.0.3",
        "@capacitor/preferences": "^7.0.2",
        "@capacitor/screen-orientation": "^7.0.2",
        "@capawesome/capacitor-android-dark-mode-support": "^7.0.0",
        "@capgo/inappbrowser": "^7.29.0",
        "@headlessui/vue": "^1.7.23",
        "@heroicons/vue": "^2.2.0",
        "@ionic/pwa-elements": "^3.3.0",
        "@wooorm/starry-night": "^3.8.0",
        "ansi_up": "^6.0.2",
        "desmos": "^1.5.4",
        "hast-util-to-html": "^9.0.5",
        "html2canvas": "^1.4.1",
        "katex": "^0.16.22",
        "marked": "^17.0.0",
        "mathjax": "^3.2.2",
        "spark-md5": "^3.0.2",
        "vite-plugin-babel": "^1.3.2",
        "vite-plugin-inspect": "^10.1.1",
        "vue": "^3.5.24",
        "vue-material-design-icons": "^5.3.1",
        "vue-router": "^4.6.3"
    },
    "devDependencies": {
        "@capacitor/cli": "^7.4.4",
        "@types/node": "^22.19.0",
        "@vitejs/plugin-vue": "^5.2.4",
        "@vitejs/plugin-vue-jsx": "^4.2.0",
        "@vue/tsconfig": "^0.7.0",
        "autoprefixer": "^10.4.21",
        "glob": "^11.0.1",
        "postcss": "^8.5.6",
        "postcss-import": "^16.1.1",
        "postcss-nesting": "^13.0.2",
        "postcss-preset-env": "^10.2.4",
        "sass": "^1.93.3",
        "terser": "^5.39.0",
        "typescript": "~5.6.2",
        "vite": "^6.4.1",
        "vue-tsc": "^2.2.12"
    },
    "browserslist": {
        "production": [
            "chrome >= 70",
            "firefox >= 65",
            "safari >= 12",
            "edge >= 79",
            "ios_saf >= 12",
            "android >= 70"
        ],
        "development": [
            "chrome >= 70",
            "firefox >= 65",
            "safari >= 12",
            "edge >= 79",
            "ios_saf >= 12",
            "android >= 70"
        ]
    }
}
